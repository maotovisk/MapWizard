<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:models="clr-namespace:MapWizard.Desktop.Models"
    x:Class="MapWizard.Desktop.Views.Controls.ComboColourDropdown"
    x:Name="Root"
    MinWidth="62">

    <UserControl.Styles>
        <Style Selector="Border.ComboTokenShell">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        </Style>

        <Style Selector="Border.ComboTokenShell:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumBrush}" />
        </Style>

        <Style Selector="Button.ComboTrigger">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="5,4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.ComboRemoveButton">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style Selector="Button.ComboRemoveButton:pointerover">
            <Setter Property="Background" Value="#22000000" />
        </Style>

        <Style Selector="Button.ComboBallButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style Selector="Button.ComboBallButton:pointerover">
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
        </Style>

        <Style Selector="Button.ComboBallButton:pointerover Border.ComboBallSwatch">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
        </Style>

        <Style Selector="Button.HeaderClose">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
    </UserControl.Styles>

    <Border Classes="ComboTokenShell">
        <Grid ColumnDefinitions="Auto,Auto,Auto" VerticalAlignment="Center">
            <Button x:Name="TriggerButton"
                    Classes="Flat Compact ComboTrigger"
                    HorizontalAlignment="Stretch"
                    Click="TriggerButton_OnClick">
                <Grid Width="24" Height="24">
                    <Border Width="24"
                            Height="24"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeAccentBrush}"
                            Background="{Binding SelectedPreviewBrush, ElementName=Root}" />
                    <TextBlock FontWeight="Bold"
                               FontSize="9"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding SelectedLabel, ElementName=Root}" />
                </Grid>

                <FlyoutBase.AttachedFlyout>
                    <Flyout Placement="BottomEdgeAlignedLeft"
                            ShowMode="Transient">
                        <Border Width="232"
                                Padding="10"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ThemeAccentBrush}"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="Select Combo"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               VerticalAlignment="Center" />

                                    <Button Grid.Column="1"
                                            Classes="HeaderClose"
                                            Click="CloseFlyout_OnClick"
                                            ToolTip.Tip="Close">
                                        <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" />
                                    </Button>
                                </Grid>

                                <Separator />

                                <ItemsControl ItemsSource="{Binding Options, ElementName=Root}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:ComboColourOption">
                                            <Button Classes="Flat Compact ComboBallButton"
                                                    Click="ComboOption_OnClick"
                                                    Tag="{Binding Number}"
                                                    ToolTip.Tip="{Binding Label}">
                                                <Grid Width="24" Height="24">
                                                    <Border Classes="ComboBallSwatch"
                                                            Width="24"
                                                            Height="24"
                                                            CornerRadius="12"
                                                            BorderThickness="1"
                                                            BorderBrush="{DynamicResource ThemeAccentBrush}"
                                                            Background="{Binding PreviewBrush}" />
                                                    <TextBlock FontWeight="Bold"
                                                               FontSize="9"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Number, StringFormat=C{0}}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>
            </Button>

            <Border Grid.Column="1"
                    Width="1"
                    Margin="0,6"
                    Background="{DynamicResource ThemeAccentBrush}"
                    Opacity="0.35" />

            <Button Grid.Column="2"
                    Classes="Flat Compact ComboRemoveButton"
                    Command="{Binding RemoveTokenCommand, ElementName=Root}"
                    CommandParameter="{Binding RemoveTokenCommandParameter, ElementName=Root}"
                    ToolTip.Tip="Remove this combo from sequence">
                <materialIcons:MaterialIcon Kind="Close" Width="12" Height="12" />
            </Button>
        </Grid>
    </Border>
</UserControl>
