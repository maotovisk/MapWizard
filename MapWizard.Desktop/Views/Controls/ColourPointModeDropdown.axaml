<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="MapWizard.Desktop.Views.Controls.ColourPointModeDropdown"
    x:Name="Root"
    MinWidth="102">

    <UserControl.Styles>
        <Style Selector="Button.ModeTrigger">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.ModeOption">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.HeaderClose">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
    </UserControl.Styles>

    <Button x:Name="TriggerButton"
            Classes="Flat Compact ModeTrigger"
            HorizontalAlignment="Stretch"
            Click="TriggerButton_OnClick">
        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6" VerticalAlignment="Center">
            <TextBlock FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Text="{Binding SelectedModeLabel, ElementName=Root}" />
            <materialIcons:MaterialIcon Grid.Column="1" Kind="ChevronDown" Width="14" Height="14" />
        </Grid>

        <FlyoutBase.AttachedFlyout>
            <Flyout Placement="BottomEdgeAlignedLeft"
                    ShowMode="Transient">
                <Border Width="168"
                        Padding="10"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeAccentBrush}"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Point Mode"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"
                                    Classes="HeaderClose"
                                    Click="CloseFlyout_OnClick"
                                    ToolTip.Tip="Close">
                                <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" />
                            </Button>
                        </Grid>

                        <Separator />

                        <Button Classes="Basic Compact ModeOption"
                                Click="SequenceOption_OnClick">
                            <TextBlock Text="Sequence" />
                        </Button>

                        <Button Classes="Basic Compact ModeOption"
                                Click="BurstOption_OnClick">
                            <TextBlock Text="Burst" />
                        </Button>
                    </StackPanel>
                </Border>
            </Flyout>
        </FlyoutBase.AttachedFlyout>
    </Button>
</UserControl>
