<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="clr-namespace:MapWizard.Desktop.Views.Controls"
  xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
  mc:Ignorable="d"
  d:DesignWidth="760"
  d:DesignHeight="460"
  x:Class="MapWizard.Desktop.Views.Controls.BeatmapSelectionPanel"
  x:Name="Root">

  <UserControl.Styles>
    <Style Selector="Border.BeatmapCard">
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="1" />
      <Setter Property="Height" Value="50" />
      <Setter Property="MinHeight" Value="50" />
      <Setter Property="MaxHeight" Value="50" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.BeatmapCard.Selected">
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="1" />
    </Style>

    <Style Selector="Border.BeatmapCardSurface">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Background" Value="#152033" />
    </Style>

    <Style Selector="Border.BeatmapCardClip">
      <Setter Property="CornerRadius" Value="13" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.BeatmapCard TextBlock">
      <Setter Property="Foreground" Value="#F2F6FF" />
    </Style>

    <Style Selector="Border.BeatmapCard materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#EAF2FF" />
    </Style>

    <Style Selector="Border.CardBadge">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="Background" Value="#77263A53" />
      <Setter Property="BorderBrush" Value="#5BA9D8FF" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.MapsetCardButton">
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Transitions">
        <Transitions />
      </Setter>
      <Setter Property="RenderTransform">
        <TransformGroup>
          <TranslateTransform X="0" Y="0" />
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </TransformGroup>
      </Setter>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  Padding="{TemplateBinding Padding}"
                  HorizontalAlignment="Stretch">
            <ContentPresenter Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="Button.MapsetCardButton:pointerover">
      <Setter Property="Opacity" Value="0.94" />
    </Style>

    <Style Selector="Button.MapsetCardButton:pressed">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="RenderTransform">
        <TransformGroup>
          <TranslateTransform X="0" Y="0" />
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </TransformGroup>
      </Setter>
    </Style>

    <Style Selector="Button.MapsetCardButton /template/ ContentPresenter">
      <Setter Property="RenderTransform">
        <TransformGroup>
          <TranslateTransform X="0" Y="0" />
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </TransformGroup>
      </Setter>
      <Setter Property="Transitions">
        <Transitions />
      </Setter>
    </Style>

    <Style Selector="Button.MapsetCardButton:pressed /template/ ContentPresenter">
      <Setter Property="RenderTransform">
        <TransformGroup>
          <TranslateTransform X="0" Y="0" />
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </TransformGroup>
      </Setter>
    </Style>

    <Style Selector="Border.BeatmapCard.MapsetCandidate">
      <Setter Property="Height" Value="50" />
      <Setter Property="MinHeight" Value="50" />
      <Setter Property="MaxHeight" Value="50" />
    </Style>

    <Style Selector="Border.EmptySelectionCard">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="Button.MapsetCollapseHeader">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="Button.MapsetCollapseHeader:pointerover">
      <Setter Property="Opacity" Value="0.92" />
    </Style>

    <Style Selector="materialIcons|MaterialIcon.MapsetChevron">
      <Setter Property="Kind" Value="ChevronRight" />
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="materialIcons|MaterialIcon.MapsetChevron.expanded">
      <Setter Property="Kind" Value="ChevronDown" />
    </Style>

    <Style Selector="Border.MapsetCollapseBody">
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="MaxHeight" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <DoubleTransition Property="MaxHeight" Duration="0:0:0.2" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.MapsetCollapseBody.expanded">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="MaxHeight" Value="1400" />
      <Setter Property="IsHitTestVisible" Value="True" />
    </Style>

    <Style Selector="Border.MapsetGroupCard">
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#3A13233A" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.DestinationMapsetCard">
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="#150E1727" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.DestinationMapsetCard TextBlock">
      <Setter Property="Foreground" Value="#F2F6FF" />
    </Style>

    <Style Selector="Border.DestinationMapsetCard materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#EAF2FF" />
    </Style>

    <Style Selector="Border.DestinationMapsetHeaderClip">
      <Setter Property="CornerRadius" Value="14,14,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.DestinationMapsetDiffs">
      <Setter Property="Background" Value="#2D101A2B" />
      <Setter Property="Padding" Value="10,8,10,4" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.MapsetGroupHeaderClip">
      <Setter Property="CornerRadius" Value="14,14,0,0" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="Border.MapsetGroupDetails">
      <Setter Property="Background" Value="#3A101A2B" />
      <Setter Property="Padding" Value="10,10,10,4" />
    </Style>

    <Style Selector="Border.MapsetSummaryPill">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="7,2" />
      <Setter Property="Background" Value="#8A162235" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style Selector="ToggleButton.MapsetDiffChip">
      <Setter Property="Margin" Value="0,0,4,4" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Background" Value="#4A1B2A44" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="ToggleButton.MapsetDiffChip:pointerover">
      <Setter Property="Background" Value="#5A263650" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="ToggleButton.MapsetDiffChip:checked">
      <Setter Property="Background" Value="#5A3C7A5D" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="ToggleButton.MapsetDiffChip TextBlock">
      <Setter Property="Foreground" Value="#F1F6FF" />
    </Style>

    <Style Selector="ToggleButton.MapsetDiffChip materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#D8F7E7" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton">
      <Setter Property="Background" Value="#7D5340A6" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="MinHeight" Value="32" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton:pointerover">
      <Setter Property="Background" Value="#8F614FB8" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton:pressed">
      <Setter Property="Background" Value="#734C3B96" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#F4F7FF" />
    </Style>

    <Style Selector="Button.DestinationMapsetChevronButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="Button.DestinationMapsetChevronButton:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="Button.DestinationMapsetChevronButton:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="Button.DestinationMapsetChevronButton materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#F4F7FF" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton.Danger">
      <Setter Property="Background" Value="#A62F3A53" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton.Danger:pointerover">
      <Setter Property="Background" Value="#BF374564" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton.Danger:pressed">
      <Setter Property="Background" Value="#8E2A3B4F" />
    </Style>

    <Style Selector="Button.DestinationMapsetIconButton.Danger materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#FFDCE3" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton">
      <Setter Property="Background" Value="#2D1E4638" />
      <Setter Property="BorderBrush" Value="#84A3E9CB" />
      <Setter Property="BorderThickness" Value="1.25" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="MinWidth" Value="108" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton:pointerover">
      <Setter Property="Background" Value="#3B2A6650" />
      <Setter Property="BorderBrush" Value="#AFC3F7DE" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton:pressed">
      <Setter Property="Background" Value="#45307159" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton.selected">
      <Setter Property="Background" Value="#3B3C7A5D" />
      <Setter Property="BorderBrush" Value="#AEEFCF" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton.selected:pointerover">
      <Setter Property="Background" Value="#445B8A69" />
      <Setter Property="BorderBrush" Value="#CCF7DE" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton.selected:pressed">
      <Setter Property="Background" Value="#4C6A9573" />
    </Style>

    <Style Selector="Button.MapsetSelectAllButton TextBlock">
      <Setter Property="Foreground" Value="#F2F6FF" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="ToolTip">
      <Setter Property="Background" Value="#EC0F1826" />
      <Setter Property="Foreground" Value="#F4F8FF" />
      <Setter Property="BorderBrush" Value="#4C89B6E9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
  </UserControl.Styles>

  <Border Margin="8"
          Padding="0"
          Background="Transparent"
          BorderBrush="Transparent"
          BorderThickness="0">
    <StackPanel Margin="12" Spacing="12">
      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
        <TextBlock Text="{Binding SectionTitle, ElementName=Root}"
                   FontWeight="SemiBold"
                   FontSize="14" />

        <Button Grid.Column="1"
                Classes="Basic"
                Command="{Binding OpenOriginFolderCommand}"
                IsEnabled="{Binding HasOriginSelection, ElementName=Root}"
                ToolTip.Tip="Open the folder of the selected origin beatmap">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <materialIcons:MaterialIcon Kind="FolderOpen" Width="18" Height="18" />
            <TextBlock Text="Open Origin Folder" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>

      <StackPanel Spacing="10">
          <TextBlock Text="Origin"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Opacity="0.9"
                     IsVisible="{Binding HasOriginSelection, ElementName=Root}" />

          <Border Classes="BeatmapCard"
                  IsVisible="{Binding HasOriginSelection, ElementName=Root}">
            <Border Classes="BeatmapCardClip">
              <Grid>
                <Border Classes="BeatmapCardSurface" />

                <Image Source="{Binding OriginMap.BackgroundImage, ElementName=Root}"
                       Stretch="UniformToFill"
                       IsVisible="{Binding OriginMap.HasBackgroundImage, ElementName=Root}" />

                <Border Background="#7A0A111B" />

                <Border>
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                      <GradientStop Offset="0" Color="#EF0A111D" />
                      <GradientStop Offset="0.45" Color="#C20E1728" />
                      <GradientStop Offset="1" Color="#72111F36" />
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>

                <Grid Margin="8"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <StackPanel Grid.Column="0"
                              VerticalAlignment="Center"
                              Spacing="1">
                    <TextBlock Text="{Binding OriginMap.DisplayTitle, ElementName=Root}"
                               FontWeight="Bold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                    <TextBlock Text="{Binding OriginMap.DisplayDetails, ElementName=Root}"
                               FontWeight="SemiBold"
                               Opacity="0.9"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                  </StackPanel>

                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center"
                              Spacing="6">
                    <StackPanel Orientation="Horizontal"
                                Spacing="4">
                      <Button Classes="Basic Compact"
                              Command="{Binding SetOriginFromMemoryCommand}"
                              Margin="0,0,4,0"
                              ToolTip.Tip="{Binding OriginMemoryToolTip, ElementName=Root}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <materialIcons:MaterialIcon Kind="Import" Width="13" Height="13" />
                          <TextBlock VerticalAlignment="Center" Text="From osu!" FontSize="11" />
                        </StackPanel>
                      </Button>
                      <Button Classes="Flat Rounded"
                              Command="{Binding PickOriginFileCommand}"
                              ToolTip.Tip="Open Map Picker dialog">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="13" Height="13" />
                          <TextBlock VerticalAlignment="Center" Text="Map Picker" FontSize="11" />
                        </StackPanel>
                      </Button>
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>
          </Border>

          <StackPanel IsVisible="{Binding HasOriginDifficultyOptions, ElementName=Root}"
                      Spacing="0">
            <Button Classes="MapsetCollapseHeader"
                    Click="OriginDiffCollapseHeaderButton_OnClick">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <materialIcons:MaterialIcon Classes="MapsetChevron"
                                            Classes.expanded="{Binding IsOriginDiffExpanded, ElementName=Root}" />
                <TextBlock Text="Origin difficulty"
                           FontWeight="SemiBold"
                           FontSize="12" />
                <TextBlock Text="{Binding SelectedOriginDifficultyLabel, ElementName=Root}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Opacity="0.82"
                           IsVisible="{Binding HasOriginDifficultyOptions, ElementName=Root}" />
              </StackPanel>
            </Button>

            <Border Classes="MapsetCollapseBody"
                    Classes.expanded="{Binding IsOriginDiffExpanded, ElementName=Root}">
              <Border Margin="0,8,0,0"
                      Classes="MapsetGroupCard">
                <Grid>
                  <Grid Margin="8,6,8,3"
                        ColumnDefinitions="*">
                    <ItemsControl VerticalAlignment="Center"
                                  ItemsSource="{Binding OriginDifficultyCards, ElementName=Root}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <ToggleButton Classes="MapsetDiffChip"
                                        IsChecked="{Binding IsSelected, Mode=OneWay}"
                                        Command="{Binding DataContext.SelectOriginMapCommand, RelativeSource={RelativeSource AncestorType=controls:BeatmapSelectionPanel}}"
                                        CommandParameter="{Binding Path}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <materialIcons:MaterialIcon Kind="CheckCircle"
                                                          Width="13"
                                                          Height="13"
                                                          IsVisible="{Binding IsSelected}" />
                              <TextBlock Text="{Binding DifficultyLabel}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         MaxWidth="260"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                          </ToggleButton>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Grid>
              </Border>
            </Border>
          </StackPanel>

          <Border Classes="EmptySelectionCard"
                  IsVisible="{Binding ShowOriginEmptyState, ElementName=Root}">
            <WrapPanel Margin="0,2,0,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Orientation="Horizontal">
              <TextBlock Text="{Binding OriginEmptyPrompt, ElementName=Root}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />
              <Button Classes="Basic Compact"
                      Command="{Binding SetOriginFromMemoryCommand}"
                      ToolTip.Tip="{Binding OriginMemoryToolTip, ElementName=Root}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <materialIcons:MaterialIcon Kind="Import" Width="16" Height="16" />
                  <TextBlock VerticalAlignment="Center" Text="From osu!" />
                </StackPanel>
              </Button>
              <TextBlock Text="or use the"
                         VerticalAlignment="Center"
                         Margin="6,0,6,0"
                         Opacity="0.8" />
              <Button Classes="Flat Compact"
                      Margin="6,0,0,0"
                      Command="{Binding PickOriginFileCommand}"
                      ToolTip.Tip="Open Map Picker dialog">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="16" Height="16" />
                  <TextBlock VerticalAlignment="Center" Text="Map Picker" />
                </StackPanel>
              </Button>
            </WrapPanel>
          </Border>
      </StackPanel>

      <StackPanel Spacing="10"
                  IsVisible="{Binding ShowDestinationSection, ElementName=Root}">
          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <TextBlock Text="Destination"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Opacity="0.9" />

            <TextBlock Grid.Column="1"
                       Text="{Binding SelectedDestinationCount, ElementName=Root, StringFormat={}{0} selected}"
                       IsVisible="{Binding HasDestinationSelection, ElementName=Root}"
                       FontSize="11"
                       Opacity="0.8" />
          </Grid>

          <StackPanel IsVisible="{Binding HasMapsetDifficultyOptions, ElementName=Root}"
                      Spacing="0">
            <Button Classes="MapsetCollapseHeader"
                    Click="MapsetCollapseHeaderButton_OnClick">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <materialIcons:MaterialIcon Classes="MapsetChevron"
                                            Classes.expanded="{Binding IsMapsetDiffExpanded, ElementName=Root}" />
                <TextBlock Text="Difficulties from origin"
                           FontWeight="SemiBold"
                           FontSize="12" />
                <TextBlock Text="{Binding SelectedMapsetDifficultyCount, ElementName=Root, StringFormat=({0} selected)}"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Opacity="0.82"
                           IsVisible="{Binding HasSelectedMapsetDifficulties, ElementName=Root}" />
              </StackPanel>
            </Button>

            <Border Classes="MapsetCollapseBody"
                    Classes.expanded="{Binding IsMapsetDiffExpanded, ElementName=Root}">
              <Border Margin="0,8,0,0"
                      Classes="MapsetGroupCard">
                <Grid>
                  <Grid Margin="8,6,8,3"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="8">
                    <ItemsControl Grid.Column="0"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding MapsetDifficultyCards, ElementName=Root}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <ToggleButton Classes="MapsetDiffChip"
                                        IsChecked="{Binding IsSelected, Mode=OneWay}"
                                        Command="{Binding DataContext.ToggleDestinationMapCommand, RelativeSource={RelativeSource AncestorType=controls:BeatmapSelectionPanel}}"
                                        CommandParameter="{Binding Path}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <materialIcons:MaterialIcon Kind="CheckCircle"
                                                          Width="13"
                                                          Height="13"
                                                          IsVisible="{Binding IsSelected}" />
                              <TextBlock Text="{Binding DifficultyLabel}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         MaxWidth="260"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                          </ToggleButton>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Grid.Column="1" Classes="MapsetSelectAllButton"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Classes.selected="{Binding AreAllMapsetDifficultiesSelected, ElementName=Root}"
                            Click="MapsetSelectAllButton_OnClick"
                            IsEnabled="{Binding CanSelectAllMapsetDifficulties, ElementName=Root}"
                            ToolTip.Tip="Select all mapset difficulties as destination maps">
                      <TextBlock Text="Select all" />
                    </Button>
                  </Grid>
                </Grid>
              </Border>
            </Border>
          </StackPanel>

          <ItemsControl IsVisible="{Binding HasVisibleDestinationCards, ElementName=Root}"
                        ItemsSource="{Binding VisibleDestinationMapsets, ElementName=Root}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="DestinationMapsetCard">
                  <Grid RowDefinitions="58,Auto">
                    <Border Grid.Row="0"
                            Classes="DestinationMapsetHeaderClip">
                      <Grid>
                        <Border Background="#152033" />

                        <Image Source="{Binding ReferenceBeatmap.BackgroundImage}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding ReferenceBeatmap.HasBackgroundImage}" />

                        <Border Background="#760A111B" />

                        <Border>
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                              <GradientStop Offset="0" Color="#EE0A111D" />
                              <GradientStop Offset="0.48" Color="#BD0E1728" />
                              <GradientStop Offset="1" Color="#68112037" />
                            </LinearGradientBrush>
                          </Border.Background>
                        </Border>
                      </Grid>
                    </Border>

                    <Grid Grid.Row="0"
                          Margin="10,7"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                      <StackPanel Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Spacing="2">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                          <TextBlock Text="{Binding ReferenceBeatmap.DisplayTitle}"
                                     FontWeight="Bold"
                                     FontSize="13"
                                     TextTrimming="CharacterEllipsis"
                                     MaxLines="1" />
                          <TextBlock Text="{Binding ReferenceBeatmap.DisplaySubtitle}"
                                     FontWeight="SemiBold"
                                     Opacity="0.9"
                                     FontSize="13"
                                     TextTrimming="CharacterEllipsis"
                                     MaxLines="1" />
                        </StackPanel>
                        <TextBlock Text="{Binding ReferenceBeatmap.DisplayDetails}"
                                   FontWeight="SemiBold"
                                   Opacity="0.9"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="6"
                                  VerticalAlignment="Center">
                        <Button Classes="DestinationMapsetChevronButton"
                                Click="DestinationMapsetExpandButton_OnClick"
                                ToolTip.Tip="Show or hide this mapset's difficulties">
                          <materialIcons:MaterialIcon Classes="MapsetChevron"
                                                      Classes.expanded="{Binding IsExpanded}" />
                        </Button>
                        <Button Classes="DestinationMapsetIconButton Danger"
                                Click="DestinationMapsetRemoveButton_OnClick"
                                ToolTip.Tip="Remove this mapset from destination">
                          <materialIcons:MaterialIcon Kind="Close" Width="18" Height="18" />
                        </Button>
                      </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Classes="MapsetCollapseBody"
                            Classes.expanded="{Binding IsExpanded}">
                      <Border Classes="DestinationMapsetDiffs">
                        <ItemsControl ItemsSource="{Binding Difficulties}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <ToggleButton Classes="MapsetDiffChip"
                                            IsChecked="{Binding IsSelected, Mode=OneWay}"
                                            Command="{Binding DataContext.ToggleDestinationMapCommand, RelativeSource={RelativeSource AncestorType=controls:BeatmapSelectionPanel}}"
                                            CommandParameter="{Binding Path}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <materialIcons:MaterialIcon Kind="CheckCircle"
                                                              Width="13"
                                                              Height="13"
                                                              IsVisible="{Binding IsSelected}" />
                                  <TextBlock Text="{Binding DifficultyLabel}"
                                             FontSize="12"
                                             FontWeight="SemiBold"
                                             MaxWidth="260"
                                             TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                              </ToggleButton>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Border>
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <WrapPanel HorizontalAlignment="Right"
                     Margin="0,0,8,0"
                     ItemHeight="34"
                     Orientation="Horizontal">
            <Button Classes="Basic"
                    Command="{Binding AddDestinationFromMemoryCommand}"
                    Margin="0,0,8,0"
                    ToolTip.Tip="{Binding DestinationMemoryToolTip, ElementName=Root}">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <materialIcons:MaterialIcon Kind="Import" Width="18" Height="18" />
                <TextBlock VerticalAlignment="Center" Text="From osu!" />
              </StackPanel>
            </Button>
            <Button Classes="Flat Rounded"
                    Command="{Binding PickDestinationFileCommand}"
                    MinWidth="122"
                    ToolTip.Tip="Open Map Picker dialog">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="18" Height="18" />
                <TextBlock VerticalAlignment="Center" Text="Map Picker" />
              </StackPanel>
            </Button>
          </WrapPanel>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
