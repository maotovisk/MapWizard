<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="clr-namespace:MapWizard.Desktop.Views.Controls"
  xmlns:converters="clr-namespace:MapWizard.Desktop.Converters"
  xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
  xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
  xmlns:theme="https://github.com/kikipoulet/SukiUI"
  mc:Ignorable="d"
  d:DesignWidth="760"
  d:DesignHeight="300"
  x:Class="MapWizard.Desktop.Views.Controls.BeatmapSelectionPanel"
  x:Name="Root">

  <UserControl.Resources>
    <converters:MapPathSummaryConverter x:Key="MapPathSummaryConverter" />
  </UserControl.Resources>

  <suki:GlassCard Margin="8" Padding="0" CornerRadius="16">
    <Grid RowDefinitions="Auto,*">
      <Grid Grid.Row="0"
            MaxHeight="{Binding HeaderMaxHeight, ElementName=Root}"
            ClipToBounds="True"
            IsVisible="{Binding ShowHeaderBackground, ElementName=Root}">
        <Image Source="{Binding HeaderBackgroundImage, ElementName=Root}"
               Stretch="UniformToFill" />

        <Border VerticalAlignment="Bottom"
                Height="{Binding HeaderOverlayHeight, ElementName=Root}">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Offset="0" Color="#00000000" />
              <GradientStop Offset="1" Color="#CC101010" />
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <StackPanel Margin="16"
                    VerticalAlignment="Bottom"
                    Spacing="4"
                    IsVisible="{Binding ShowHeaderContext, ElementName=Root}">
          <TextBlock FontWeight="Bold"
                     FontSize="14"
                     Text="{Binding HeaderTopLine, ElementName=Root}"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="1" />
          <TextBlock Text="{Binding HeaderBottomLine, ElementName=Root}"
                     IsVisible="{Binding ShowHeaderBottomLine, ElementName=Root}"
                     TextWrapping="Wrap"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="2"
                     FontSize="12" />
        </StackPanel>
      </Grid>

      <StackPanel Grid.Row="1" Spacing="8" Margin="12">
        <TextBlock Text="{Binding SectionTitle, ElementName=Root}" />
        <Separator />

        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
          <Grid Margin="0,0,8,0">
            <TextBox x:Name="OriginPathEditTextBox"
                     theme:TextBoxExtensions.Prefix="{Binding FromPrefix, ElementName=Root}"
                     Watermark="{Binding FromWatermark, ElementName=Root}"
                     Text="{Binding OriginBeatmap.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsEditingOriginPath, ElementName=Root}"
                     LostFocus="OriginPathEditTextBox_OnLostFocus"
                     KeyDown="OriginPathEditTextBox_OnKeyDown" />

            <TextBox theme:TextBoxExtensions.Prefix="{Binding FromPrefix, ElementName=Root}"
                     x:Name="OriginPathSummaryTextBox"
                     Text="{Binding OriginBeatmap.Path, Mode=OneWay, Converter={StaticResource MapPathSummaryConverter}}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     IsReadOnly="True"
                     IsVisible="{Binding ShowOriginSummary, ElementName=Root}"
                     ToolTip.Tip="Click to edit full path"
                     GotFocus="OriginPathSummaryTextBox_OnGotFocus"
                     PointerPressed="OriginPathSummaryTextBox_OnPointerPressed" />
          </Grid>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Classes="Basic"
                    Command="{Binding PickOriginFileCommand}"
                    ToolTip.Tip="Open Map Picker dialog">
              <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="24" Height="24" />
                <TextBlock VerticalAlignment="Center" Text="Map Picker" />
              </StackPanel>
            </Button>
            <Button Classes="Flat Rounded"
                    Command="{Binding SetOriginFromMemoryCommand}"
                    MinWidth="122"
                    ToolTip.Tip="{Binding OriginMemoryToolTip, ElementName=Root}">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <materialIcons:MaterialIcon Kind="Import" Width="24" Height="24" />
                <TextBlock VerticalAlignment="Center" Text="From osu!" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>

        <StackPanel IsVisible="{Binding ShowDestinationSelection, ElementName=Root}" Spacing="8">
          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <Grid Margin="0,0,8,0">
              <TextBox x:Name="DestinationPathEditTextBox"
                       theme:TextBoxExtensions.Prefix="{Binding ToPrefix, ElementName=Root}"
                       Watermark="{Binding ToWatermark, ElementName=Root}"
                       Text="{Binding DestinationBeatmaps[0].Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsEditingDestinationPath, ElementName=Root}"
                       LostFocus="DestinationPathEditTextBox_OnLostFocus"
                       KeyDown="DestinationPathEditTextBox_OnKeyDown" />

              <TextBox theme:TextBoxExtensions.Prefix="{Binding ToPrefix, ElementName=Root}"
                       x:Name="DestinationPathSummaryTextBox"
                       Text="{Binding DestinationBeatmaps[0].Path, Mode=OneWay, Converter={StaticResource MapPathSummaryConverter}}"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       IsReadOnly="True"
                       IsVisible="{Binding ShowDestinationSummary, ElementName=Root}"
                       ToolTip.Tip="Click to edit full path"
                       GotFocus="DestinationPathSummaryTextBox_OnGotFocus"
                       PointerPressed="DestinationPathSummaryTextBox_OnPointerPressed" />
            </Grid>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
              <Button IsVisible="{Binding HasMultiple}"
                      Command="{Binding RemoveMapCommand}"
                      CommandParameter="{Binding DestinationBeatmaps[0].Path}"
                      Classes="Basic"
                      ToolTip.Tip="Remove this beatmap from the list">
                <materialIcons:MaterialIcon Kind="Close" Width="24" Height="24" />
              </Button>
              <Button Classes="Basic"
                      Command="{Binding PickDestinationFileCommand}"
                      ToolTip.Tip="Open Map Picker dialog">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="24" Height="24" />
                  <TextBlock VerticalAlignment="Center" Text="Map Picker" />
                </StackPanel>
              </Button>
              <Button Classes="Flat Rounded"
                      Command="{Binding AddDestinationFromMemoryCommand}"
                      MinWidth="122"
                      ToolTip.Tip="{Binding DestinationMemoryToolTip, ElementName=Root}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <materialIcons:MaterialIcon Kind="Import" Width="24" Height="24" />
                  <TextBlock VerticalAlignment="Center" Text="From osu!" />
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>

          <ItemsControl Margin="0,8,0,0"
                        IsVisible="{Binding HasMultiple}"
                        ItemsSource="{Binding AdditionalBeatmaps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="*,Auto">
                  <Grid Margin="0,0, 8,8">
                    <TextBox
                      theme:TextBoxExtensions.Prefix="{Binding AdditionalPrefix, RelativeSource={RelativeSource AncestorType=controls:BeatmapSelectionPanel}}"
                      Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Stretch"
                      IsVisible="False"
                      LostFocus="AdditionalPathEditTextBox_OnLostFocus"
                      KeyDown="AdditionalPathEditTextBox_OnKeyDown" />

                    <TextBox
                      x:Name="AdditionalPathSummaryTextBox"
                      theme:TextBoxExtensions.Prefix="{Binding AdditionalPrefix, RelativeSource={RelativeSource AncestorType=controls:BeatmapSelectionPanel}}"
                      Text="{Binding Path, Mode=OneWay, Converter={StaticResource MapPathSummaryConverter}}"
                      HorizontalAlignment="Stretch"
                      IsReadOnly="True"
                      ToolTip.Tip="Click to edit full path"
                      GotFocus="AdditionalPathSummaryTextBox_OnGotFocus"
                      PointerPressed="AdditionalPathSummaryTextBox_OnPointerPressed" />
                  </Grid>
                  <Button Grid.Column="1"
                          Command="{Binding DataContext.RemoveMapCommand, RelativeSource={RelativeSource AncestorType=controls:BeatmapSelectionPanel}}"
                          CommandParameter="{Binding Path}"
                          Classes="Basic"
                          ToolTip.Tip="Remove this beatmap from the list">
                    <materialIcons:MaterialIcon Kind="Close" Width="24" Height="24" />
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock IsVisible="{Binding HasMultiple}"
                     Text="{Binding DestinationBeatmaps.Count, StringFormat=({0} selected beatmaps)}"
                     Margin="0,8,0,0" />
        </StackPanel>
      </StackPanel>
    </Grid>
  </suki:GlassCard>
</UserControl>
