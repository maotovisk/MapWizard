<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="MapWizard.Desktop.Views.Controls.ModernColorPicker"
    x:Name="Root"
    MinWidth="150">
    <UserControl.Styles>
        <Style Selector="Button.HeaderClose">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style Selector="Button.PickerTrigger">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Button.PresetSwatch">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="2" />
        </Style>

        <Style Selector="TextBlock.ChannelLabel">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>

        <Style Selector="TextBlock.ChannelValue">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Button x:Name="TriggerButton"
                Classes="Flat Compact PickerTrigger"
                HorizontalAlignment="Stretch"
                Click="TriggerButton_OnClick">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                <Border x:Name="CompactPreviewSwatch"
                        Width="18"
                        Height="18"
                        CornerRadius="9"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeAccentBrush}" />
                <TextBlock x:Name="CompactHexText"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="#FFFFFF" />
                <materialIcons:MaterialIcon Grid.Column="2" Kind="ChevronDown" Width="16" Height="16" />
            </Grid>

            <FlyoutBase.AttachedFlyout>
                <Flyout Placement="BottomEdgeAlignedLeft"
                        ShowMode="Transient">
                    <Border Width="300"
                            Padding="12"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ThemeAccentBrush}"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Color Picker"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           VerticalAlignment="Center" />

                                <Button Grid.Column="1"
                                        Classes="HeaderClose"
                                        Click="CloseFlyout_OnClick"
                                        ToolTip.Tip="Close">
                                    <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" />
                                </Button>
                            </Grid>
                            <Separator />

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                <Border x:Name="PopupPreviewSwatch"
                                        Width="30"
                                        Height="30"
                                        CornerRadius="15"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource ThemeAccentBrush}" />

                                <TextBox x:Name="HexTextBox"
                                         Grid.Column="1"
                                         Watermark="#RRGGBB"
                                         VerticalContentAlignment="Center"
                                         TextChanged="HexTextBox_OnTextChanged" />

                                <Button Grid.Column="2"
                                        Classes="Flat Compact"
                                        Click="ApplyHexColor_Click"
                                        ToolTip.Tip="Apply hex color">
                                    <materialIcons:MaterialIcon Kind="Palette" Width="16" Height="16" />
                                </Button>
                            </Grid>

                            <UniformGrid Columns="8" Rows="1" HorizontalAlignment="Stretch">
                                <Button Classes="PresetSwatch" Tag="#FF4D4D" Click="PresetColor_OnClick" Background="#FF4D4D" />
                                <Button Classes="PresetSwatch" Tag="#FFB84D" Click="PresetColor_OnClick" Background="#FFB84D" />
                                <Button Classes="PresetSwatch" Tag="#F2FF4D" Click="PresetColor_OnClick" Background="#F2FF4D" />
                                <Button Classes="PresetSwatch" Tag="#5CFF66" Click="PresetColor_OnClick" Background="#5CFF66" />
                                <Button Classes="PresetSwatch" Tag="#4DFFF5" Click="PresetColor_OnClick" Background="#4DFFF5" />
                                <Button Classes="PresetSwatch" Tag="#4D7DFF" Click="PresetColor_OnClick" Background="#4D7DFF" />
                                <Button Classes="PresetSwatch" Tag="#B04DFF" Click="PresetColor_OnClick" Background="#B04DFF" />
                                <Button Classes="PresetSwatch" Tag="#FFFFFF" Click="PresetColor_OnClick" Background="#FFFFFF" />
                            </UniformGrid>

                            <StackPanel Spacing="7">
                                <Grid ColumnDefinitions="16,*,36" ColumnSpacing="8">
                                    <TextBlock Classes="ChannelLabel" Text="R" VerticalAlignment="Center" />
                                    <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" />
                                    <TextBlock Grid.Column="2" Classes="ChannelValue"
                                               Text="{Binding Value, ElementName=RedSlider, StringFormat={}{0:0}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*,36" ColumnSpacing="8">
                                    <TextBlock Classes="ChannelLabel" Text="G" VerticalAlignment="Center" />
                                    <Slider x:Name="GreenSlider" Grid.Column="1" Minimum="0" Maximum="255" />
                                    <TextBlock Grid.Column="2" Classes="ChannelValue"
                                               Text="{Binding Value, ElementName=GreenSlider, StringFormat={}{0:0}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </Grid>

                                <Grid ColumnDefinitions="16,*,36" ColumnSpacing="8">
                                    <TextBlock Classes="ChannelLabel" Text="B" VerticalAlignment="Center" />
                                    <Slider x:Name="BlueSlider" Grid.Column="1" Minimum="0" Maximum="255" />
                                    <TextBlock Grid.Column="2" Classes="ChannelValue"
                                               Text="{Binding Value, ElementName=BlueSlider, StringFormat={}{0:0}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Flyout>
            </FlyoutBase.AttachedFlyout>
        </Button>
    </Grid>
</UserControl>
