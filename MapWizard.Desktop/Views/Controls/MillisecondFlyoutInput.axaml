<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="MapWizard.Desktop.Views.Controls.MillisecondFlyoutInput"
    x:Name="Root"
    MinWidth="126">

    <UserControl.Styles>
        <Style Selector="Button.TimeTrigger">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.HeaderClose">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
    </UserControl.Styles>

    <Button x:Name="TriggerButton"
            Classes="Flat Compact TimeTrigger"
            HorizontalAlignment="Stretch"
            Click="TriggerButton_OnClick">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" VerticalAlignment="Center">
            <materialIcons:MaterialIcon Kind="TimerOutline" Width="14" Height="14" />
            <TextBlock Grid.Column="1"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Text="{Binding DisplayValue, ElementName=Root}" />
            <materialIcons:MaterialIcon Grid.Column="2" Kind="ChevronDown" Width="14" Height="14" />
        </Grid>

        <FlyoutBase.AttachedFlyout>
            <Flyout Placement="BottomEdgeAlignedLeft"
                    ShowMode="Transient"
                    Opened="Flyout_OnOpened">
                <Border Width="220"
                        Padding="10"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ThemeAccentBrush}"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Point Time (ms)"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"
                                    Classes="HeaderClose"
                                    Click="CloseFlyout_OnClick"
                                    ToolTip.Tip="Close">
                                <materialIcons:MaterialIcon Kind="Close" Width="16" Height="16" />
                            </Button>
                        </Grid>

                        <Separator />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox x:Name="InputTextBox"
                                     Grid.Column="0"
                                     Watermark="0"
                                     VerticalContentAlignment="Center"
                                     PastingFromClipboard="InputTextBox_OnPastingFromClipboard"
                                     KeyDown="InputTextBox_OnKeyDown" />

                            <Button Grid.Column="1"
                                    Classes="Basic Compact"
                                    Click="ApplyButton_OnClick"
                                    ToolTip.Tip="Apply time">
                                <materialIcons:MaterialIcon Kind="Check" Width="16" Height="16" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Flyout>
        </FlyoutBase.AttachedFlyout>
    </Button>
</UserControl>
