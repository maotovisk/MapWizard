<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MapWizard.Desktop.Converters"
    xmlns:controls="clr-namespace:MapWizard.Desktop.Views.Controls"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:theme="https://github.com/kikipoulet/SukiUI"
    xmlns:vm="clr-namespace:MapWizard.Desktop.ViewModels"
    mc:Ignorable="d"
    d:DesignWidth="900"
    d:DesignHeight="700"
    x:Class="MapWizard.Desktop.Views.ComboColourStudioView"
    x:DataType="vm:ComboColourStudioViewModel"
    Padding="16">

    <UserControl.Resources>
        <local:AvaloniaColorToColorConverter x:Key="AvaloniaColorToColorConverter" />
    </UserControl.Resources>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveProjectCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Grid.Row="0"
                           Text="Combo Colour Studio"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="16,0" />

                <Border IsVisible="{Binding HasOriginBeatmap}"
                        CornerRadius="12"
                        Padding="10,4"
                        BorderBrush="{DynamicResource ThemeAccentBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <materialIcons:MaterialIcon Kind="CheckCircle"
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="#64D58A"
                                                    IsVisible="{Binding IsProjectSavedIndicatorVisible}" />
                        <TextBlock Text="Saved"
                                   FontSize="12"
                                   IsVisible="{Binding IsProjectSavedIndicatorVisible}" />

                        <materialIcons:MaterialIcon Kind="CircleEditOutline"
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="#E8C57A"
                                                    IsVisible="{Binding IsProjectUnsavedIndicatorVisible}" />
                        <TextBlock Text="Unsaved changes"
                                   FontSize="12"
                                   IsVisible="{Binding IsProjectUnsavedIndicatorVisible}" />

                        <materialIcons:MaterialIcon Kind="CircleOutline"
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="{DynamicResource SukiLowText}"
                                                    IsVisible="{Binding IsProjectNotSavedIndicatorVisible}" />
                        <TextBlock Text="Not saved"
                                   FontSize="12"
                                   IsVisible="{Binding IsProjectNotSavedIndicatorVisible}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Classes="Basic Large"
                        Command="{Binding SaveProjectCommand}"
                        IsEnabled="{Binding CanSaveProject}"
                        ToolTip.Tip="Save local combo project (Ctrl+S)">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <materialIcons:MaterialIcon Kind="ContentSaveOutline" Width="24" Height="24" />
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Text="Save Project" />
                    </StackPanel>
                </Button>

                <Button Classes="Flat Large"
                        Command="{Binding ExportColourHaxCommand}"
                        ToolTip.Tip="Export colour hax to destination beatmaps">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <materialIcons:MaterialIcon Kind="ContentSave" Width="24" Height="24" />
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Text="Apply / Export" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Separator Grid.Row="1" Margin="0 10 0 5" />

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="16">
                <suki:GlassCard Margin="8" Padding="0" CornerRadius="16">
                    <Grid RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" MaxHeight="140" ClipToBounds="True" IsVisible="{Binding HasHeaderBackgroundImage}">
                            <Image Source="{Binding HeaderBackgroundImage}"
                                   Stretch="UniformToFill"
                                   />

                            <Border VerticalAlignment="Bottom" Height="78">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#00000000" />
                                        <GradientStop Offset="1" Color="#CC101010" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <StackPanel Margin="16"
                                        VerticalAlignment="Bottom"
                                        Spacing="4"
                                        IsVisible="{Binding HasOriginBeatmap}">
                                <TextBlock FontWeight="Bold"
                                           FontSize="14"
                                           Text="{Binding OriginContextTopLine}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                                <TextBlock Text="{Binding OriginContextBottomLine}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Spacing="8" Margin="12">
                            <TextBlock Text="Beatmap Selection" />
                            <Separator />

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBox theme:TextBoxExtensions.Prefix="From: "
                                         Watermark="Load combo colours from..."
                                         Text="{Binding OriginBeatmap.Path, Mode=TwoWay}"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Classes="Basic"
                                            Command="{Binding PickOriginFileCommand}"
                                            ToolTip.Tip="Open Song Select dialog">
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="24" Height="24" />
                                            <TextBlock VerticalAlignment="Center" Text="Song Select" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="Flat Rounded"
                                            Command="{Binding PickOriginFileManuallyCommand}"
                                            ToolTip.Tip="Open native file picker fallback">
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="24" Height="24" />
                                            <TextBlock VerticalAlignment="Center" Text="Manual" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="Flat Rounded"
                                            Command="{Binding SetOriginFromMemoryCommand}"
                                            ToolTip.Tip="Use currently selected osu! beatmap">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <materialIcons:MaterialIcon Kind="Import" Width="24" Height="24" />
                                            <TextBlock VerticalAlignment="Center" Text="Select current" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBox theme:TextBoxExtensions.Prefix="To: "
                                         Watermark="Export colour hax to..."
                                         Text="{Binding DestinationBeatmaps[0].Path, Mode=TwoWay}"
                                         HorizontalAlignment="Stretch"
                                         Margin="0,0,8,0" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button IsVisible="{Binding HasMultiple}"
                                            Classes="Basic"
                                            Command="{Binding RemoveMapCommand}"
                                            CommandParameter="{Binding DestinationBeatmaps[0].Path}"
                                            ToolTip.Tip="Remove this beatmap from the list">
                                        <materialIcons:MaterialIcon Kind="Close" Width="24" Height="24" />
                                    </Button>
                                    <Button Classes="Basic"
                                            Command="{Binding PickDestinationFileCommand}"
                                            ToolTip.Tip="Open Song Select dialog">
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="24" Height="24" />
                                            <TextBlock VerticalAlignment="Center" Text="Song Select" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="Flat Rounded"
                                            Command="{Binding PickDestinationFileManuallyCommand}"
                                            ToolTip.Tip="Open native file picker fallback">
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="24" Height="24" />
                                            <TextBlock VerticalAlignment="Center" Text="Manual" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="Flat Rounded"
                                            Command="{Binding AddDestinationFromMemoryCommand}"
                                            ToolTip.Tip="Add currently selected osu! beatmap">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <materialIcons:MaterialIcon Kind="Import" Width="24" Height="24" />
                                            <TextBlock VerticalAlignment="Center" Text="Add current" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding AdditionalBeatmaps}" IsVisible="{Binding HasMultiple}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Text="{Binding Path, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding DataContext.RemoveMapCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Path}"
                                                    Classes="Basic"
                                                    ToolTip.Tip="Remove this beatmap from the list">
                                                <materialIcons:MaterialIcon Kind="Close" Width="24" Height="24" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock IsVisible="{Binding HasMultiple}"
                                       Text="{Binding DestinationBeatmaps.Count, StringFormat=There are {0} selected beatmaps.}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </suki:GlassCard>

                <suki:GlassCard Margin="8" Padding="12" CornerRadius="15">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Combo Colours" FontWeight="Bold" FontSize="16" />
                        <Separator />

                        <ItemsControl ItemsSource="{Binding ComboColours}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                                        <TextBlock FontWeight="Bold"
                                                   Text="{Binding Number, StringFormat=Combo {0}}"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <controls:ModernColorPicker
                                                SelectedColor="{Binding Colour, Converter={StaticResource AvaloniaColorToColorConverter}, Mode=TwoWay}" />
                                            <Button Classes="Basic"
                                                    Command="{Binding DataContext.RemoveColourCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Remove this combo colour">
                                                <materialIcons:MaterialIcon Kind="Close" Width="20" Height="20" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                            <Button Classes="Basic" Command="{Binding AddColourCommand}" ToolTip.Tip="Add new combo colour">
                                <materialIcons:MaterialIcon Kind="Add" Width="24" Height="24" />
                            </Button>

                            <TextBlock Grid.Column="1" Text="Palette size" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="2"
                                           Width="80"
                                           Minimum="1"
                                           Maximum="8"
                                           FormatString="N0"
                                           Value="{Binding PaletteSize, Mode=TwoWay}" />

                            <Button Grid.Column="3"
                                    Classes="Basic"
                                    Command="{Binding GenerateColoursFromBackgroundCommand}"
                                    ToolTip.Tip="Generate combo colours from beatmap background">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <materialIcons:MaterialIcon Kind="ImageFilterCenterFocusStrong" Width="18" Height="18" />
                                    <TextBlock Text="From BG" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4"
                                    HorizontalAlignment="Left"
                                    Classes="Basic"
                                    Command="{Binding PickImageAndGenerateColoursCommand}"
                                    ToolTip.Tip="Generate combo colours from selected image">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <materialIcons:MaterialIcon Kind="FolderImage" Width="18" Height="18" />
                                    <TextBlock Text="From Image" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </suki:GlassCard>

                <suki:GlassCard Margin="8" Padding="12" CornerRadius="15">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Colour Points" FontWeight="Bold" FontSize="16" />

                            <Button Grid.Column="1"
                                    Classes="Basic"
                                    Command="{Binding ImportColourHaxFromOriginCommand}"
                                    ToolTip.Tip="Import colour hax from selected origin beatmap">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <materialIcons:MaterialIcon Kind="Import" Width="18" Height="18" />
                                    <TextBlock Text="Import ColourHax" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Classes="Basic"
                                    Command="{Binding AddColourPointCommand}"
                                    ToolTip.Tip="Add colour point">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <materialIcons:MaterialIcon Kind="Add" Width="18" Height="18" />
                                    <TextBlock Text="Add Point" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Separator />

                        <ItemsControl ItemsSource="{Binding ColourPoints}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource ThemeAccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="8"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                            <controls:MillisecondFlyoutInput Width="130"
                                                                             Value="{Binding Time, Mode=TwoWay}" />

                                            <controls:ColourPointModeDropdown Grid.Column="1"
                                                                              Width="102"
                                                                              SelectedMode="{Binding Mode, Mode=TwoWay}" />

                                            <ScrollViewer Grid.Column="2"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ColourSequence}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <controls:ComboColourDropdown
                                                                Options="{Binding DataContext.ColourDropdownOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                SelectedComboNumber="{Binding ComboNumber, Mode=TwoWay}"
                                                                RemoveTokenCommand="{Binding DataContext.RemoveColourFromPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                RemoveTokenCommandParameter="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <Button Grid.Column="3"
                                                    Classes="Basic"
                                                    Command="{Binding DataContext.AddColourToPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Add combo colour to this point sequence">
                                                <materialIcons:MaterialIcon Kind="Add" Width="16" Height="16" />
                                            </Button>

                                            <Button Grid.Column="4"
                                                    Classes="Basic"
                                                    Command="{Binding DataContext.RemoveColourPointCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="Remove this colour point">
                                                <materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </suki:GlassCard>

                <suki:GlassCard Margin="8" Padding="12" CornerRadius="15">
                    <suki:GroupBox Header="Object Burst">
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Max burst length" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1"
                                               theme:NumericUpDownExtensions.Unit="objects"
                                               FormatString="N0"
                                               Minimum="1"
                                               Maximum="16"
                                               Value="{Binding MaxBurstLength, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </suki:GroupBox>
                </suki:GlassCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
