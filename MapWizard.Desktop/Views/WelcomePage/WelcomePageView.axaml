<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="clr-namespace:MapWizard.Desktop.ViewModels"
    xmlns:ia="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="MapWizard.Desktop.Views.WelcomePageView"
    x:DataType="vm:WelcomePageViewModel"
    Padding="24">
    <Interaction.Behaviors>
        <RoutedEventTriggerBehavior RoutedEvent="{x:Static Control.LoadedEvent}">
            <InvokeCommandAction Command="{Binding WindowStartupCommand}" />
        </RoutedEventTriggerBehavior>
    </Interaction.Behaviors>

    <Grid RowDefinitions="Auto,*" VerticalAlignment="Center" RowSpacing="20">
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Welcome to MapWizard" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
            <Button Classes="Flat Rounded" Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <materialIcons:MaterialIcon Kind="Update" />
                    <TextBlock VerticalAlignment="Center" Text="Check for updates" />
                </StackPanel>
            </Button>
            
            <TextBlock HorizontalAlignment="Center" Text="Select a tool to get started."></TextBlock>
        </StackPanel>
        

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" ItemSpacing="10" Orientation="Horizontal">
                <Grid Margin="15">
                    <suki:GlassCard Width="260" Height="220" Margin="0,0,0,25" Padding="16" CornerRadius="18">
                        <StackPanel VerticalAlignment="Center" Spacing="12">
                            <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center" Background="{DynamicResource ThemeAccentBrush}" Opacity="0.2">
                                <materialIcons:MaterialIcon Kind="ContentCopy" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Hitsound Copier" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Copy hitsounds between difficulties fast."
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </suki:GlassCard>
                    <Button Width="160"
                            Height="40"
                            Margin="0,0,0,7"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Classes="Flat Rounded"
                            Click="OpenHitSoundCopier_OnClick">
                        Open
                    </Button>
                </Grid>

                <Grid Margin="15">
                    <suki:GlassCard Width="260" Height="220" Margin="0,0,0,25" Padding="16" CornerRadius="18">
                        <StackPanel VerticalAlignment="Center" Spacing="12">
                            <Border Width="56" Height="56" CornerRadius="28" HorizontalAlignment="Center" Background="{DynamicResource ThemeAccentBrush}" Opacity="0.2">
                                <materialIcons:MaterialIcon Kind="FileDocumentMultiple" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Metadata Manager" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                            <TextBlock Text="Edit and sync metadata across maps."
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </suki:GlassCard>
                    <Button Width="160"
                            Height="40"
                            Margin="0,0,0,7"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Classes="Flat Rounded"
                            Click="OpenMetadataManager_OnClick">
                        Open
                    </Button>
                </Grid>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
