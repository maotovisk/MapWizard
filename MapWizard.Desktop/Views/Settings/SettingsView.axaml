<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:MapWizard.Desktop.ViewModels"
    xmlns:controls="clr-namespace:MapWizard.Desktop.Views.Controls"
    xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:objectModel="clr-namespace:System.Collections.ObjectModel;assembly=System.ObjectModel"
    x:Class="MapWizard.Desktop.Views.SettingsView"
    x:DataType="vm:SettingsViewModel"
    d:DesignWidth="800"
    d:DesignHeight="450"
    mc:Ignorable="d"
    Padding="24">
    <suki:SettingsLayout>
        <suki:SettingsLayout.Items>
            <objectModel:ObservableCollection x:TypeArguments="suki:SettingsLayoutItem">
                <suki:SettingsLayoutItem Header="General">
                    <suki:SettingsLayoutItem.Content>
                        <StackPanel Spacing="20">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Dark Theme" FontWeight="Bold" />
                                    <TextBlock Text="Switch between light and dark while keeping the MapWizard custom color theme."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                              HorizontalAlignment="Right" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Update Stream" FontWeight="Bold" />
                                    <TextBlock Text="Release checks only stable releases. PreRelease checks both pre-releases and stable releases."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <controls:AppDropdown Grid.Column="1"
                                                      FlyoutMinWidth="180"
                                                      MinWidth="140"
                                                      PlaceholderText="Select update stream"
                                                      ItemsSource="{Binding UpdateStreams}"
                                                      SelectedItem="{Binding UpdateStream, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Top">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Songs Folder" FontWeight="Bold" />
                                    <TextBlock Text="Map Picker uses this folder to display recent beatmaps and their backgrounds."
                                               TextWrapping="Wrap" />
                                    <TextBox Text="{Binding SongsPath, Mode=TwoWay}"
                                             Watermark="Path to osu! Songs folder"
                                             Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding SongsPathStatusText}"
                                               FontSize="12"
                                               Opacity="0.82" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Classes="Basic"
                                        VerticalAlignment="Top"
                                        Command="{Binding PickSongsFolderCommand}">
                                    <TextBlock Text="Browse" />
                                </Button>

                                <Button Grid.Column="2"
                                        Classes="Flat"
                                        VerticalAlignment="Top"
                                        Command="{Binding AutoDetectSongsFolderCommand}">
                                    <TextBlock Text="Auto Detect" />
                                </Button>
                            </Grid>

                            <Button Classes="Flat Compact"
                                    HorizontalAlignment="Left"
                                    IsEnabled="{Binding CanRestartToApplyUpdate}"
                                    Command="{Binding RestartToApplyUpdateCommand}">
                                <TextBlock Text="{Binding UpdateStreamBadgeText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextDecorations="Underline" />
                            </Button>
                        </StackPanel>
                    </suki:SettingsLayoutItem.Content>
                </suki:SettingsLayoutItem>

                <suki:SettingsLayoutItem Header="Audio">
                    <suki:SettingsLayoutItem.Content>
                        <StackPanel Spacing="20">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Audio Output Device" FontWeight="Bold" />
                                    <TextBlock Text="Select the playback device used by editor audio preview features."
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding AudioOutputDeviceStatusText}"
                                               FontSize="12"
                                               Opacity="0.82" />
                                </StackPanel>
                                <controls:AppDropdown Grid.Column="1"
                                                      MinWidth="260"
                                                      MaxWidth="380"
                                                      FlyoutMinWidth="320"
                                                      PlaceholderText="Select output device"
                                                      ItemsSource="{Binding AudioOutputDevices}"
                                                      SelectedItem="{Binding SelectedAudioOutputDevice, Mode=TwoWay}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Preview Song Volume" FontWeight="Bold" />
                                    <TextBlock Text="Default music volume for editor audio previews (including the Hitsound Visualizer)."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Slider Width="180"
                                            Minimum="0"
                                            Maximum="100"
                                            TickFrequency="1"
                                            Value="{Binding AudioPreviewSongVolumePercent, Mode=TwoWay}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding AudioPreviewSongVolumePercent, StringFormat={}{0}%}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Preview Hitsound Volume" FontWeight="Bold" />
                                    <TextBlock Text="Default hitsound volume for editor audio previews (including the Hitsound Visualizer)."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Slider Width="180"
                                            Minimum="0"
                                            Maximum="100"
                                            TickFrequency="1"
                                            Value="{Binding AudioPreviewHitSoundVolumePercent, Mode=TwoWay}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding AudioPreviewHitSoundVolumePercent, StringFormat={}{0}%}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </suki:SettingsLayoutItem.Content>
                </suki:SettingsLayoutItem>

                <suki:SettingsLayoutItem Header="Information">
                    <suki:SettingsLayoutItem.Content>
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <TextBlock Text="Config Directory:" />
                            <TextBlock Grid.Column="1" Text="{Binding ConfigDirectoryPath}" FontWeight="Bold" />
                        </Grid>
                    </suki:SettingsLayoutItem.Content>
                </suki:SettingsLayoutItem>
            </objectModel:ObservableCollection>
        </suki:SettingsLayout.Items>
    </suki:SettingsLayout>
</UserControl>
